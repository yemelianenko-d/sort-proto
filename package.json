{
  "name": "sort-proto",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Technical prototype of a sorting puzzle mechanic for a future puzzle hub (web/mobile browser).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src tools",
    "format": "prettier --write \"src/**/*.ts\" \"tools/**/*.mjs\"",
    "levels:generate": "node tools/generate-levels.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/neucha": "^5.2.8",
    "phaser": "^3.85.2",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
}
